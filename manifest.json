{
  "manifest_version": 3,
  "name": "Gmail Subscription Manager",
  "version": "1.0.0",
  "description": "Scan, manage, and unsubscribe from email newsletters directly in Chrome.",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Gmail Subscription Manager"
  },
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "permissions": [
    "identity",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://mail.google.com/*",
    "*://*/*"
  ],
  "oauth2": {
    "client_id": "27604081588-lujk8ge28bb94qe8m5l4jpgrg8kueke1.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/gmail.modify",
      "https://www.googleapis.com/auth/gmail.send"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
